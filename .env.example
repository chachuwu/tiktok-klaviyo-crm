# ============================================================
# TikTok App Credentials
# ============================================================
# Your TikTok for Business app ID (from TikTok Marketing API)
TIKTOK_APP_ID=your_tiktok_app_id

# Your TikTok for Business app secret (from TikTok Marketing API)
TIKTOK_APP_SECRET=your_tiktok_app_secret

# OAuth redirect URI (must match TikTok app configuration)
TIKTOK_REDIRECT_URI=https://your-domain.com/auth/tiktok/callback

# TikTok API base URL (default: https://business-api.tiktok.com)
TIKTOK_API_BASE_URL=https://business-api.tiktok.com

# TikTok API version (default: v1.3)
TIKTOK_API_VERSION=v1.3

# Optional: Static access token (fallback if OAuth not configured)
TIKTOK_ACCESS_TOKEN=

# Optional: Default CRM Event Set ID (fallback if not auto-provisioned)
TIKTOK_CRM_EVENT_SET_ID=

# Default advertiser ID (fallback when advertiser can't be resolved from event)
TIKTOK_DEFAULT_ADVERTISER_ID=

# TikTok Lead Gen Webhook HMAC secret (for verifying webhook signatures)
TIKTOK_LEAD_WEBHOOK_SECRET=your_tiktok_lead_webhook_secret

# Rate limiting: requests per second to TikTok API (default: 10)
TIKTOK_RATE_LIMIT_RPS=10

# Maximum retry attempts on TikTok API failures (default: 5)
TIKTOK_MAX_RETRIES=5

# Initial retry delay in milliseconds (default: 1000)
TIKTOK_INITIAL_RETRY_DELAY_MS=1000

# Batch size for TikTok events API (max 50, default: 50)
TIKTOK_BATCH_SIZE=50

# ============================================================
# Klaviyo Credentials
# ============================================================
# Klaviyo private API key (starts with pk_)
KLAVIYO_PRIVATE_API_KEY=pk_your_klaviyo_private_api_key

# HMAC-SHA256 secret for Klaviyo webhook signature verification
KLAVIYO_WEBHOOK_SECRET=your_klaviyo_webhook_secret

# Klaviyo API base URL (default: https://a.klaviyo.com)
KLAVIYO_API_BASE_URL=https://a.klaviyo.com

# ============================================================
# Redis Configuration
# ============================================================
# Redis connection URL (default: redis://localhost:6379)
REDIS_URL=redis://localhost:6379

# Deduplication TTL in seconds (default: 172800 = 48 hours)
REDIS_DEDUP_TTL_SECONDS=172800

# ============================================================
# PostgreSQL Configuration
# ============================================================
# PostgreSQL connection URL
POSTGRES_URL=postgresql://crm_user:crm_password@localhost:5432/crm_events

# ============================================================
# Admin API Key
# ============================================================
# Secret key required in X-Admin-Api-Key header for /auth and /event-sets routes
# Must be at least 32 characters. Generate with: openssl rand -hex 32
ADMIN_API_KEY=your_admin_api_key_at_least_32_chars_long

# ============================================================
# Application Configuration
# ============================================================
# HTTP port to listen on (default: 3000)
PORT=3000

# Node environment: development | production | test
NODE_ENV=development

# Log level: trace | debug | info | warn | error | fatal (default: info)
LOG_LEVEL=info

# Integration version for tracking in events (default: 1.0.0)
INTEGRATION_VERSION=1.0.0
